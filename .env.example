# =============================================================================
# Sentinel RAG Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=sentinel-rag
ENVIRONMENT=production
# production | development | staging
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_HOSTS=rag.example.com

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinel_rag
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change-me

# -----------------------------------------------------------------------------
# MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=sentinel-admin
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Ollama
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434

# -----------------------------------------------------------------------------
# LLM Providers (leave empty to disable)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Default LLM provider: anthropic | openai | google | ollama
DEFAULT_LLM_PROVIDER=ollama
# Default embedding provider: openai | google | ollama
DEFAULT_EMBEDDING_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Proxy (for external API access)
# -----------------------------------------------------------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,qdrant,minio,ollama,keycloak,vault

# -----------------------------------------------------------------------------
# SSO / OIDC
# -----------------------------------------------------------------------------
OIDC_ISSUER_URL=https://keycloak.example.com/realms/sentinel
OIDC_CLIENT_ID=sentinel-rag
OIDC_CLIENT_SECRET=change-me

# -----------------------------------------------------------------------------
# TLS
# -----------------------------------------------------------------------------
TLS_CERT_PATH=/etc/nginx/tls/server.crt
TLS_KEY_PATH=/etc/nginx/tls/server.key

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_NAS_PATH=/mnt/backup
BACKUP_ENCRYPTION_KEY=change-me

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------
ALERT_EMAIL_TO=
ALERT_SLACK_WEBHOOK=
ALERT_TEAMS_WEBHOOK=
